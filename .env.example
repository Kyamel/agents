# Runtime
APP_ENV=development
HTTP_PORT=8080

# HTTPS
ENABLE_HTTPS=false
HTTPS_PORT=8443
HTTPS_CERT_FILE=./certs/dev-cert.pem
HTTPS_KEY_FILE=./certs/dev-key.pem
HTTPS_KEY_PASSWORD=
TRUST_PROXY=false

# SQLite
DB_PATH=./data/agents.db

# Security
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX=120
AUTH_SESSION_TTL_MIN=10080
AGENT_MAX_SOURCE_BYTES=65536
AGENT_TURN_TIMEOUT_MS=50
AGENT_MAX_INFERENCES=100000

# Auth / email
RESEND_API_KEY=
RESEND_FROM=noreply@example.com
APP_BASE_URL=https://localhost:8443
EMAIL_VERIFY_TTL_MIN=30
