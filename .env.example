# Runtime
APP_ENV=development
HTTP_PORT=8080

# Reverse proxy / TLS
# TLS deve ser terminado no proxy (ex. Caddy). O app so fala HTTP.
# Quando atras de um proxy, ative TRUST_PROXY para honrar os headers
# X-Forwarded-* no rate limiter.
TRUST_PROXY=false

# SQLite
DB_PATH=./data/agents.db

# Security
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX=120
AUTH_SESSION_TTL_MIN=10080
AGENT_MAX_SOURCE_BYTES=65536
AGENT_TURN_TIMEOUT_MS=50
AGENT_MAX_INFERENCES=100000

# Auth / email
# MAIL_TRANSPORT: console | resend
#   - vazio: auto (console em dev / sem RESEND_API_KEY; resend caso contrario)
#   - console: imprime o link de verificacao no terminal (sem enviar email)
#   - resend: forca envio via API do Resend
MAIL_TRANSPORT=
RESEND_API_KEY=
RESEND_FROM=noreply@example.com
APP_BASE_URL=http://localhost:8080
EMAIL_VERIFY_TTL_MIN=30

ENGINE_SCENARIO=
ENGINE_QDIS=3