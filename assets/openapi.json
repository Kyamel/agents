{
  "openapi": "3.0.3",
  "info": {
    "title": "Scotland Yard Agents API",
    "version": "1.0.0",
    "description": "API JSON para cadastro, autenticação, envio de agentes Prolog e criação/consulta de partidas."
  },
  "servers": [
    {
      "url": "/",
      "description": "Mesmo host em que a documentação foi aberta"
    }
  ],
  "tags": [
    { "name": "Auth" },
    { "name": "Agents" },
    { "name": "Matches" },
    { "name": "Users" },
    { "name": "Jobs" },
    { "name": "Health" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Verifica se o serviço está ativo",
        "responses": {
          "200": {
            "description": "Serviço ativo",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/signup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Cria uma conta",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SignupRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Conta criada",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SignupResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": {
            "description": "Email já cadastrado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "email_already_exists" }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Autentica usuário e devolve token Bearer",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LoginResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": {
            "description": "Email ainda não verificado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "email_not_verified" }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/verify": {
      "get": {
        "tags": ["Auth"],
        "summary": "Verifica email usando token",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Email verificado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VerifyResponse" }
              }
            }
          },
          "400": {
            "description": "Token inválido ou expirado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "invalid_or_expired_token" }
              }
            }
          }
        }
      }
    },
    "/api/v1/agents": {
      "get": {
        "tags": ["Agents"],
        "summary": "Lista agentes cadastrados",
        "parameters": [
          { "$ref": "#/components/parameters/CursorQuery" },
          { "$ref": "#/components/parameters/LimitQuery" }
        ],
        "responses": {
          "200": {
            "description": "Lista de agentes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "agents": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Agent" }
                    },
                    "next_cursor": { "type": "string" },
                    "limit": { "type": "integer", "example": 20 }
                  },
                  "required": ["agents", "next_cursor", "limit"]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Agents"],
        "summary": "Envia um agente Prolog",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateAgentRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Agente criado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateAgentResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": {
            "description": "Usuário não encontrado ou email não verificado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "error": "email_not_verified_or_user_not_found" }
              }
            }
          },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/api/v1/agents/{id}": {
      "get": {
        "tags": ["Agents"],
        "summary": "Consulta um agente",
        "parameters": [
          { "$ref": "#/components/parameters/IdPath" }
        ],
        "responses": {
          "200": {
            "description": "Agente encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "agent": { "$ref": "#/components/schemas/Agent" }
                  },
                  "required": ["agent"]
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/matches": {
      "get": {
        "tags": ["Matches"],
        "summary": "Lista partidas",
        "parameters": [
          { "$ref": "#/components/parameters/CursorQuery" },
          { "$ref": "#/components/parameters/LimitQuery" }
        ],
        "responses": {
          "200": {
            "description": "Lista de partidas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "matches": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/MatchSummary" }
                    },
                    "next_cursor": { "type": "string" },
                    "limit": { "type": "integer", "example": 20 }
                  },
                  "required": ["matches", "next_cursor", "limit"]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Matches"],
        "summary": "Cria e enfileira uma partida",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMatchRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Partida enfileirada",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateMatchResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/api/v1/matches/{id}": {
      "get": {
        "tags": ["Matches"],
        "summary": "Consulta uma partida",
        "parameters": [
          { "$ref": "#/components/parameters/IdPath" }
        ],
        "responses": {
          "200": {
            "description": "Partida encontrada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "match": { "$ref": "#/components/schemas/MatchWithReplay" }
                  },
                  "required": ["match"]
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/users/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Consulta perfil público com estatísticas",
        "parameters": [
          { "$ref": "#/components/parameters/IdPath" }
        ],
        "responses": {
          "200": {
            "description": "Perfil encontrado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserProfileResponse" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/jobs": {
      "get": {
        "tags": ["Jobs"],
        "summary": "Lista jobs de partidas em execução",
        "responses": {
          "200": {
            "description": "Lista de jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "jobs": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Job" }
                    }
                  },
                  "required": ["jobs"]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{id}": {
      "get": {
        "tags": ["Jobs"],
        "summary": "Consulta o status de um job por id da partida",
        "parameters": [
          { "$ref": "#/components/parameters/IdPath" }
        ],
        "responses": {
          "200": {
            "description": "Job encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "job": { "$ref": "#/components/schemas/Job" }
                  },
                  "required": ["job"]
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "parameters": {
      "IdPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer", "minimum": 1 }
      },
      "CursorQuery": {
        "name": "cursor",
        "in": "query",
        "required": false,
        "description": "Cursor retornado em `next_cursor` pela página anterior. Ausente ou vazio retorna a primeira página.",
        "schema": { "type": "string" }
      },
      "LimitQuery": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "Quantidade de itens por página. Valor efetivo entre 1 e 100.",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Corpo ou parâmetros inválidos",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Token ausente ou inválido",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "error": "unauthorized" }
          }
        }
      },
      "NotFound": {
        "description": "Recurso não encontrado",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "Dados válidos em JSON, mas recusados pela regra de negócio",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        },
        "required": ["error"]
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "ok" },
          "service": { "type": "string", "example": "agents-battle-api" }
        },
        "required": ["status", "service"]
      },
      "SignupRequest": {
        "type": "object",
        "properties": {
          "username": { "type": "string", "example": "Lucas" },
          "email": { "type": "string", "format": "email", "example": "lucas@example.com" },
          "password": { "type": "string", "format": "password", "example": "secret123" }
        },
        "required": ["username", "email", "password"]
      },
      "SignupResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "created" },
          "user_id": { "type": "integer" },
          "username": { "type": "string" },
          "email_delivery": { "type": "string", "enum": ["sent", "console", "failed"] },
          "message": { "type": "string" }
        },
        "required": ["status", "user_id", "username", "email_delivery", "message"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password" }
        },
        "required": ["email", "password"]
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "ok" },
          "token": { "type": "string" },
          "user_id": { "type": "integer" },
          "expires_at": { "type": "string", "format": "date-time" }
        },
        "required": ["status", "token", "user_id", "expires_at"]
      },
      "VerifyResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "verified" },
          "user_id": { "type": "integer" }
        },
        "required": ["status", "user_id"]
      },
      "Agent": {
        "type": "object",
        "description": "Metadados do agente. No detalhe `/api/v1/agents/{id}`, `source` aparece apenas quando `is_private` for false.",
        "properties": {
          "id": { "type": "integer" },
          "owner_user_id": { "type": "integer" },
          "name": { "type": "string", "maxLength": 60, "example": "agenteL" },
          "role": { "type": "string", "enum": ["thief", "detective"] },
          "is_private": { "type": "boolean", "default": false },
          "deleted_at": {
            "type": "string",
            "nullable": true,
            "description": "Data do soft delete. Ausente ou vazio para agentes ativos."
          },
          "source": {
            "type": "string",
            "description": "Codigo Prolog do agente, presente apenas quando o agente nao for privado."
          },
          "created_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "owner_user_id", "name", "role", "is_private", "created_at"]
      },
      "CreateAgentRequest": {
        "type": "object",
        "description": "O nome do agente é extraído da diretiva `:- module(Nome, Exports).` no código Prolog.",
        "properties": {
          "role": { "type": "string", "enum": ["thief", "detective"] },
          "private": {
            "type": "boolean",
            "default": false,
            "description": "Quando true, o codigo nao e exibido no detalhe publico do agente."
          },
          "source": {
            "type": "string",
            "example": ":- module('agenteL', [ladrao_action/3, ladrao_preload/7])."
          }
        },
        "required": ["role", "source"]
      },
      "CreateAgentResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "created" },
          "agent": { "$ref": "#/components/schemas/Agent" }
        },
        "required": ["status", "agent"]
      },
      "CreateMatchRequest": {
        "type": "object",
        "properties": {
          "thief_agent_id": { "type": "integer" },
          "detective_agent_id": { "type": "integer" },
          "scenario": { "type": "string", "description": "Opcional; usa o cenário padrão quando ausente." }
        },
        "required": ["thief_agent_id", "detective_agent_id"]
      },
      "CreateMatchResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "queued" },
          "match_id": { "type": "integer" }
        },
        "required": ["status", "match_id"]
      },
      "Match": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "thief_agent_id": { "type": "integer" },
          "detective_agent_id": { "type": "integer" },
          "scenario": { "type": "string" },
          "winner": {
            "type": "string",
            "description": "Resultado normalizado quando disponível.",
            "x-extensible-enum": ["thief", "detective", "draw", ""]
          },
          "replay_json": { "type": "string" },
          "status": {
            "type": "string",
            "description": "Estado atual da partida.",
            "x-extensible-enum": ["queued", "running", "done", "timeout", "error"]
          },
          "created_at": { "type": "string", "format": "date-time" },
          "started_at": { "type": "string" },
          "finished_at": { "type": "string" }
        },
        "required": ["id", "thief_agent_id", "detective_agent_id", "winner", "status", "created_at"]
      },
      "MatchSummary": {
        "type": "object",
        "description": "Resumo de partida usado em listagens. Não inclui `replay_json`; consulte `/api/v1/matches/{id}` para obter o replay estruturado.",
        "properties": {
          "id": { "type": "integer" },
          "thief_agent_id": { "type": "integer" },
          "detective_agent_id": { "type": "integer" },
          "scenario": { "type": "string" },
          "winner": {
            "type": "string",
            "description": "Resultado normalizado quando disponível.",
            "x-extensible-enum": ["thief", "detective", "draw", ""]
          },
          "status": {
            "type": "string",
            "description": "Estado atual da partida.",
            "x-extensible-enum": ["queued", "running", "done", "timeout", "error"]
          },
          "created_at": { "type": "string", "format": "date-time" },
          "started_at": { "type": "string" },
          "finished_at": { "type": "string" }
        },
        "required": ["id", "thief_agent_id", "detective_agent_id", "winner", "status", "created_at"]
      },
      "MatchWithReplay": {
        "allOf": [
          { "$ref": "#/components/schemas/Match" },
          {
            "type": "object",
            "properties": {
              "replay": { "$ref": "#/components/schemas/Replay" }
            }
          }
        ]
      },
      "Replay": {
        "type": "object",
        "description": "Replay estruturado gerado a partir da saída textual da engine. Em partidas ainda não concluídas, esse campo pode estar ausente.",
        "properties": {
          "scenario": {
            "type": "string",
            "description": "Nome do cenário usado pela engine."
          },
          "winner": {
            "type": "string",
            "description": "Resultado normalizado da partida.",
            "x-extensible-enum": ["thief", "detective", "draw"]
          },
          "final_turn": {
            "type": "integer",
            "minimum": 0,
            "description": "Quantidade de turnos agrupados no replay."
          },
          "setup": {
            "$ref": "#/components/schemas/ReplaySetup"
          },
          "turns": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ReplayTurn" }
          },
          "events": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ReplayEvent" }
          }
        },
        "required": ["scenario", "winner", "final_turn", "setup", "turns", "events"]
      },
      "ReplaySetup": {
        "type": "object",
        "description": "Estado inicial resumido da partida.",
        "properties": {
          "scenario": {
            "type": "string",
            "description": "Nome do cenário usado pela engine."
          },
          "thief_id": {
            "type": "integer",
            "description": "Identidade/suspeito escolhido para o ladrão."
          },
          "thief_start": {
            "type": "string",
            "description": "Cidade inicial do ladrão."
          },
          "detective_start": {
            "type": "string",
            "description": "Cidade inicial do detetive."
          },
          "target": {
            "type": "string",
            "description": "Tesouro-alvo do ladrão."
          },
          "disguises": {
            "type": "integer",
            "minimum": 0
          },
          "max_turns": {
            "type": "integer",
            "minimum": 0
          },
          "appearance": {
            "type": "array",
            "description": "Atributos da aparência real do ladrão serializados como texto Prolog.",
            "items": { "type": "string" }
          }
        },
        "required": ["scenario"]
      },
      "ReplayTurn": {
        "type": "object",
        "description": "Ações do ladrão e do detetive em um turno da engine.",
        "properties": {
          "turn": {
            "type": "integer"
          },
          "thief_action": {
            "type": "string",
            "description": "Ação do ladrão serializada como texto Prolog."
          },
          "thief_status": {
            "type": "string",
            "description": "Status retornado pela engine para a ação do ladrão.",
            "x-extensible-enum": ["OK", "Ilegal", ""]
          },
          "thief_position": {
            "type": "string",
            "description": "Destino quando a ação do ladrão é move/2; '-' para outras ações."
          },
          "detective_action": {
            "type": "string",
            "description": "Ação do detetive serializada como texto Prolog."
          },
          "detective_status": {
            "type": "string",
            "description": "Status retornado pela engine para a ação do detetive.",
            "x-extensible-enum": ["OK", "Ilegal", ""]
          },
          "detective_position": {
            "type": "string",
            "description": "Destino quando a ação do detetive é move/2; '-' para outras ações."
          },
          "events": {
            "type": "array",
            "description": "Eventos associados à ação deste turno, normalmente roubo.",
            "items": { "$ref": "#/components/schemas/ReplayTurnEvent" }
          }
        },
        "required": [
          "turn",
          "thief_action",
          "thief_status",
          "thief_position",
          "detective_action",
          "detective_status",
          "detective_position",
          "events"
        ]
      },
      "ReplayTurnEvent": {
        "type": "object",
        "description": "Evento anexado ao log de uma ação dentro de um turno.",
        "properties": {
          "type": {
            "type": "string",
            "description": "Tipo do evento.",
            "x-extensible-enum": ["robbery", "unknown"]
          },
          "item": {
            "type": "string",
            "description": "Item roubado, quando o evento é um roubo."
          },
          "city": {
            "type": "string",
            "description": "Cidade associada ao evento, quando disponível."
          },
          "revealed": {
            "type": "array",
            "description": "Pistas reveladas pelo evento, quando houver.",
            "items": { "type": "string" }
          },
          "detail": {
            "type": "string",
            "description": "Texto bruto para eventos não estruturados."
          }
        },
        "required": ["type"]
      },
      "ReplayEvent": {
        "type": "object",
        "description": "Evento na linha do tempo global do replay.",
        "properties": {
          "type": {
            "type": "string",
            "description": "Tipo do evento.",
            "x-extensible-enum": ["robbery", "unknown"]
          },
          "item": {
            "type": "string",
            "description": "Item roubado, quando o evento é um roubo."
          },
          "city": {
            "type": "string",
            "description": "Cidade associada ao evento, quando disponível."
          },
          "revealed": {
            "type": "array",
            "description": "Pistas reveladas pelo evento, quando houver.",
            "items": { "type": "string" }
          },
          "detail": {
            "type": "string",
            "description": "Texto bruto para eventos não estruturados."
          },
          "turn": {
            "type": "integer",
            "description": "Turno em que o evento foi associado."
          },
          "by": {
            "type": "string",
            "description": "Agente associado ao evento.",
            "x-extensible-enum": ["thief", "detective"]
          }
        },
        "required": ["type", "turn", "by"]
      },
      "Stats": {
        "type": "object",
        "properties": {
          "wins": { "type": "integer", "minimum": 0 },
          "losses": { "type": "integer", "minimum": 0 },
          "draws": { "type": "integer", "minimum": 0 }
        },
        "required": ["wins", "losses", "draws"]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "username": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "is_verified": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "username", "email", "is_verified", "created_at"]
      },
      "AgentWithStats": {
        "allOf": [
          { "$ref": "#/components/schemas/Agent" },
          {
            "type": "object",
            "properties": {
              "stats": { "$ref": "#/components/schemas/Stats" }
            },
            "required": ["stats"]
          }
        ]
      },
      "UserProfileResponse": {
        "type": "object",
        "properties": {
          "user": { "$ref": "#/components/schemas/User" },
          "stats": { "$ref": "#/components/schemas/Stats" },
          "agents": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AgentWithStats" }
          }
        },
        "required": ["user", "stats", "agents"]
      },
      "Job": {
        "type": "object",
        "properties": {
          "match_id": { "type": "integer" },
          "status": { "type": "string" },
          "elapsed_seconds": {
            "oneOf": [
              { "type": "number" },
              { "type": "null" }
            ]
          },
          "pid": {
            "oneOf": [
              { "type": "integer" },
              { "type": "null" }
            ]
          },
          "thief_id": { "type": "integer" },
          "detective_id": { "type": "integer" },
          "scenario": { "type": "string" }
        },
        "required": ["match_id", "status"]
      }
    }
  }
}
